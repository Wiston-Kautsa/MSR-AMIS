<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="950.0"
            xmlns="http://javafx.com/javafx/11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AddEquipmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>

        <!-- SCROLLABLE ROOT -->
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    AnchorPane.topAnchor="0"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0">

            <content>

                <VBox spacing="20" prefWidth="900">
                    <padding>
                        <Insets top="20" left="20" right="20" bottom="20"/>
                    </padding>

                    <!-- TITLE -->
                    <Label text="Add Equipment"
                           style="-fx-font-size:20px; -fx-font-weight:bold;" />

                    <!-- ================= MANUAL ENTRY ================= -->
                    <TitledPane text="Manual Equipment Entry" expanded="true">

                        <content>

                            <GridPane hgap="15" vgap="15">

                                <padding>
                                    <Insets top="10" left="10" right="10" bottom="10"/>
                                </padding>

                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30"/>
                                    <ColumnConstraints percentWidth="70"/>
                                </columnConstraints>

                                <!-- NAME -->
                                <Label text="Equipment Name:" GridPane.rowIndex="0"/>
                                <TextField fx:id="txtName"
                                           promptText="Example: Tablet"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="1"/>

                                <!-- CATEGORY -->
                                <Label text="Category:" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="cmbCategory"
                                          prefWidth="250"
                                          GridPane.rowIndex="1"
                                          GridPane.columnIndex="1"/>

                                <!-- SERIAL -->
                                <Label text="Serial / IMEI:" GridPane.rowIndex="2"/>
                                <TextField fx:id="txtSerialNumber"
                                           promptText="IMEI or Serial Number"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1"/>

                                <!-- SOURCE -->
                                <Label text="Source:" GridPane.rowIndex="3"/>
                                <TextField fx:id="txtSource"
                                           promptText="Example: World Bank"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="1"/>

                                <!-- CONDITION -->
                                <Label text="Condition:" GridPane.rowIndex="4"/>
                                <ComboBox fx:id="cmbCondition"
                                          prefWidth="250"
                                          GridPane.rowIndex="4"
                                          GridPane.columnIndex="1"/>

                                <!-- DATE -->
                                <Label text="Entry Date:" GridPane.rowIndex="5"/>
                                <DatePicker fx:id="dateEntry"
                                            GridPane.rowIndex="5"
                                            GridPane.columnIndex="1"/>

                            </GridPane>

                        </content>

                    </TitledPane>

                    <!-- ================= ACTION BUTTONS ================= -->
                    <HBox spacing="15" alignment="CENTER_RIGHT">

                        <Button text="Save Equipment"
                                onAction="#saveEquipment"
                                style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

                        <Button text="Clear"
                                onAction="#clearForm"
                                style="-fx-background-color:#95a5a6; -fx-text-fill:white;"/>

                    </HBox>

                    <!-- ================= BULK IMPORT ================= -->
                    <TitledPane text="Bulk Equipment Import (Excel)" expanded="true">

                        <content>

                            <VBox spacing="10">

                                <padding>
                                    <Insets top="10" left="10" right="10" bottom="10"/>
                                </padding>

                                <Label text="Upload Excel file containing equipment list."/>

                                <!-- FILE NAME DISPLAY -->
                                <Label fx:id="lblSelectedFile"
                                       text="No file selected"
                                       style="-fx-text-fill: gray;"/>

                                <HBox spacing="10">

                                    <Button text="Choose Excel File"
                                            onAction="#chooseExcelFile"/>

                                    <Button text="Upload"
                                            onAction="#uploadExcel"
                                            style="-fx-background-color:#3498db; -fx-text-fill:white;"/>

                                </HBox>

                            </VBox>

                        </content>

                    </TitledPane>

                    <!-- ================= EQUIPMENT TABLE ================= -->
                    <TitledPane text="Equipment Inventory" expanded="true">

                        <content>

                            <TableView fx:id="equipmentTable" prefHeight="300">

                                <columns>

                                    <TableColumn fx:id="colName"
                                                 text="Name"
                                                 prefWidth="150"/>

                                    <TableColumn fx:id="colCategory"
                                                 text="Category"
                                                 prefWidth="120"/>

                                    <TableColumn fx:id="colSerial"
                                                 text="Serial / IMEI"
                                                 prefWidth="200"/>

                                </columns>

                            </TableView>

                        </content>

                    </TitledPane>

                </VBox>

            </content>

        </ScrollPane>

    </children>

</AnchorPane>