<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="540.0" prefWidth="940.0"
            styleClass="login-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.LoginController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>
        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0">
            <children>
                <HBox maxWidth="900.0"
                      maxHeight="460.0"
                      prefHeight="460.0"
                      prefWidth="900.0"
                      styleClass="login-shell">
                    <children>
                        <VBox prefWidth="430.0"
                              spacing="16.0"
                              alignment="CENTER_LEFT"
                              styleClass="login-brand-panel">
                            <padding>
                                <Insets top="42.0" right="42.0" bottom="42.0" left="42.0"/>
                            </padding>
                            <children>
                                <Label text="MSR AMIS" styleClass="login-brand-title"/>
                                <Label text="Malawi Social Registry" styleClass="login-brand-subtitle"/>
                                <Label text="Asset Management Information System"
                                       wrapText="true"
                                       styleClass="login-brand-subtitle"/>
                                <Label text="Track assets, assignments, returns, and reporting in one secure desktop system."
                                       wrapText="true"
                                       styleClass="login-brand-description"/>
                                <Label text="Secure asset tracking and management"
                                       wrapText="true"
                                       styleClass="login-brand-footnote"/>
                            </children>
                        </VBox>

                        <VBox prefWidth="470.0"
                              spacing="18.0"
                              alignment="CENTER_LEFT"
                              styleClass="login-card-panel">
                            <padding>
                                <Insets top="42.0" right="52.0" bottom="42.0" left="52.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Welcome Back" styleClass="login-title"/>
                                        <Label text="Sign in to continue to the system" styleClass="login-subtitle"/>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Email" styleClass="login-input-label"/>
                                        <TextField fx:id="txtEmail"
                                                   promptText="Enter your email"
                                                   prefHeight="44.0"
                                                   maxWidth="1.7976931348623157E308"
                                                   styleClass="login-input"/>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Password" styleClass="login-input-label"/>
                                        <StackPane>
                                            <children>
                                                <PasswordField fx:id="txtPassword"
                                                               promptText="Enter your password"
                                                               prefHeight="44.0"
                                                               maxWidth="1.7976931348623157E308"
                                                               styleClass="login-input"/>
                                                <TextField fx:id="txtPasswordVisible"
                                                           promptText="Enter your password"
                                                           prefHeight="44.0"
                                                           maxWidth="1.7976931348623157E308"
                                                           managed="false"
                                                           visible="false"
                                                           styleClass="login-input"/>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <CheckBox fx:id="chkShowPassword"
                                          text="Show password"
                                          styleClass="login-checkbox"/>

                                <Button text="LOGIN"
                                        prefHeight="46.0"
                                        maxWidth="1.7976931348623157E308"
                                        onAction="#handleLogin"
                                        styleClass="login-primary-button"/>

                                <HBox spacing="10.0">
                                    <children>
                                        <Button text="Clear"
                                                prefHeight="40.0"
                                                maxWidth="1.7976931348623157E308"
                                                HBox.hgrow="ALWAYS"
                                                onAction="#handleClear"
                                                styleClass="login-secondary-button"/>
                                        <Button text="Reset Password"
                                                prefHeight="40.0"
                                                maxWidth="1.7976931348623157E308"
                                                HBox.hgrow="ALWAYS"
                                                onAction="#handleResetPassword"
                                                styleClass="login-secondary-button"/>
                                    </children>
                                </HBox>

                                <Label fx:id="lblLoginStatus"
                                       wrapText="true"
                                       styleClass="login-message"/>
                                <Label fx:id="lblDefaultAdmin"
                                       wrapText="true"
                                       styleClass="login-helper"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </StackPane>
    </children>

</AnchorPane>
