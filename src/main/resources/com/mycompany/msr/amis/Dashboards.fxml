<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1100"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.DashboardsController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <!-- ================= HEADER ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header">
            <padding>
                <Insets top="15" bottom="15" left="20" right="20"/>
            </padding>

            <children>
                <Label text="MSR Asset Management System"
                       styleClass="header-title"/>
            </children>
        </HBox>
    </top>

    <!-- ================= SIDEBAR ================= -->
    <left>
        <VBox spacing="15" prefWidth="260" styleClass="sidebar">

            <padding>
                <Insets top="20" left="15" right="15" bottom="20"/>
            </padding>

            <children>

                <Label text="MSR-AMIS" styleClass="logo"/>

                <Separator/>

                <Button text="Dashboard"
                        styleClass="sidebar-button"
                        onAction="#openDashboard"/>

                <Accordion VBox.vgrow="ALWAYS">

                    <panes>

                        <TitledPane text="Equipment Inventory">
                            <content>
                                <VBox spacing="5">
                                    <children>

                                        <Button text="Add Equipment"
                                                styleClass="submenu-button"
                                                onAction="#openAddEquipment"/>

                                        <Button text="Equipment List"
                                                styleClass="submenu-button"
                                                onAction="#openEquipmentList"/>

                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Equipment Issuing">
                            <content>
                                <VBox spacing="5">
                                    <children>

                                        <Button text="Create Assignment"
                                                styleClass="submenu-button"
                                                onAction="#openCreateAssignment"/>

                                        <Button text="Distribute Equipment"
                                                styleClass="submenu-button"
                                                onAction="#openDistributeEquipment"/>

                                        <Button text="Distribution List"
                                                styleClass="submenu-button"
                                                onAction="#openDistributionReport"/>

                                        <Button text="Assignment List"
                                                styleClass="submenu-button"
                                                onAction="#openAssignmentList"/>

                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Equipment Return">
                            <content>
                                <VBox spacing="5">
                                    <children>

                                        <Button text="Return Equipment"
                                                styleClass="submenu-button"
                                                onAction="#openReturnEquipment"/>

                                        <Button text="Return Equipment List"
                                                styleClass="submenu-button"
                                                onAction="#openReturnReport"/>

                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Reports">
                            <content>
                                <VBox spacing="5">
                                    <children>

                                        <Button text="Inventory Report"
                                                styleClass="submenu-button"
                                                onAction="#openInventoryReport"/>

                                        <Button text="Assignment Report"
                                                styleClass="submenu-button"
                                                onAction="#openAssignmentReport"/>

                                        <Button text="Distribution Report"
                                                styleClass="submenu-button"
                                                onAction="#openDistributionReport"/>

                                        <Button text="Return Report"
                                                styleClass="submenu-button"
                                                onAction="#openReturnReport"/>

                                        <Button text="Outstanding Report"
                                                styleClass="submenu-button"
                                                onAction="#openOutstandingReport"/>

                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                    </panes>

                </Accordion>

                <Separator/>

                <Button text="Users"
                        styleClass="sidebar-button"
                        onAction="#openUsers"/>

                <Button text="About Us"
                        styleClass="sidebar-button"
                        onAction="#openAboutUs"/>

                <Separator/>

                <Button text="Logout"
                        styleClass="sidebar-button"
                        onAction="#openLogout"/>

            </children>

        </VBox>
    </left>

    <!-- ================= CONTENT ================= -->
    <center>
        <StackPane fx:id="contentArea">

            <children>

                <ScrollPane fitToWidth="true" fitToHeight="true"
                            hbarPolicy="NEVER"
                            styleClass="dashboard-scroll">

                    <content>
                        <VBox spacing="25"
                              fillWidth="true"
                              styleClass="dashboard-content"
                              style="-fx-padding:30;">

                            <children>

                                <Label text="Dashboard"
                                       styleClass="header-title" />

                                <TitledPane text="Summary Overview"
                                            expanded="true"
                                            collapsible="true"
                                            styleClass="dashboard-section">
                                    <content>
                                        <HBox spacing="20" fillHeight="true" styleClass="dashboard-section-content">

                                            <children>

                                                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Assets Entered" styleClass="card-title"/>
                                                        <Label fx:id="lblAssetsEntered"
                                                               text="0"
                                                               styleClass="card-value"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Available Assets" styleClass="card-title"/>
                                                        <Label fx:id="lblAvailableAssets"
                                                               text="0"
                                                               styleClass="card-value"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Issued Assets" styleClass="card-title"/>
                                                        <Label fx:id="lblIssuedAssets"
                                                               text="0"
                                                               styleClass="card-value"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Waiting Return" styleClass="card-title"/>
                                                        <Label fx:id="lblWaitingReturn"
                                                               text="0"
                                                               styleClass="card-value"/>
                                                    </children>
                                                </VBox>

                                            </children>

                                        </HBox>
                                    </content>
                                </TitledPane>

                                <TitledPane text="Equipment Charts"
                                            expanded="true"
                                            collapsible="true"
                                            styleClass="dashboard-section">
                                    <content>
                                        <GridPane hgap="20" vgap="20" VBox.vgrow="ALWAYS" styleClass="dashboard-section-content">

                                            <columnConstraints>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                                            </columnConstraints>

                                            <rowConstraints>
                                                <RowConstraints vgrow="ALWAYS"/>
                                            </rowConstraints>

                                            <children>

                                                <VBox spacing="10" styleClass="card chart-card"
                                                      GridPane.columnIndex="0" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Available Equipment (By Category)"
                                                               styleClass="card-title"/>

                                                        <PieChart fx:id="equipmentPieChart"
                                                                  styleClass="dashboard-pie-chart"
                                                                  labelsVisible="true"
                                                                  legendVisible="true"
                                                                  minHeight="280"
                                                                  prefHeight="360"
                                                                  maxHeight="1.7976931348623157E308"
                                                                  maxWidth="1.7976931348623157E308"
                                                                  clockwise="true"
                                                                  VBox.vgrow="ALWAYS"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="10" styleClass="card chart-card"
                                                      GridPane.columnIndex="1" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Issued Equipment (By Category)"
                                                               styleClass="card-title"/>

                                                        <PieChart fx:id="borrowedPieChart"
                                                                  styleClass="dashboard-pie-chart"
                                                                  labelsVisible="true"
                                                                  legendVisible="true"
                                                                  minHeight="280"
                                                                  prefHeight="360"
                                                                  maxHeight="1.7976931348623157E308"
                                                                  maxWidth="1.7976931348623157E308"
                                                                  clockwise="true"
                                                                  VBox.vgrow="ALWAYS"/>
                                                    </children>
                                                </VBox>

                                            </children>
                                        </GridPane>
                                    </content>
                                </TitledPane>

                            </children>

                        </VBox>
                    </content>
                </ScrollPane>

            </children>

        </StackPane>
    </center>

</BorderPane>
