<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AssignmentReportController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>

        <!-- ================= TITLE ================= -->
        <Label text="Assignment Report"
               layoutX="20" layoutY="20"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <!-- ================= FILTER SECTION ================= -->
        <HBox spacing="10" layoutX="20" layoutY="60">

            <ComboBox fx:id="cmbOfficer" promptText="Select Officer" prefWidth="180"/>
            <ComboBox fx:id="cmbEquipmentType" promptText="Equipment Type" prefWidth="180"/>
            <ComboBox fx:id="cmbStatus" promptText="Status" prefWidth="150"/>

            <Button text="Filter" onAction="#handleFilter"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
            <Button text="Export" onAction="#handleExport"/>

        </HBox>

        <!-- ================= TABLE ================= -->
        <TableView fx:id="tableAssignments"
                   layoutX="20" layoutY="110"
                   prefWidth="860" prefHeight="450">

            <columns>

                <TableColumn fx:id="colAssignmentName"
                             text="Assignment"
                             prefWidth="120"/>

                <TableColumn fx:id="colOfficer"
                             text="Officer"
                             prefWidth="140"/>

                <TableColumn fx:id="colPhone"
                             text="Phone"
                             prefWidth="120"/>

                <TableColumn fx:id="colNID"
                             text="NID"
                             prefWidth="140"/>

                <TableColumn fx:id="colEquipment"
                             text="Equipment"
                             prefWidth="140"/>

                <TableColumn fx:id="colCategory"
                             text="Category"
                             prefWidth="120"/>

                <TableColumn fx:id="colStatus"
                             text="Status"
                             prefWidth="120"/>

                <TableColumn fx:id="colDate"
                             text="Date"
                             prefWidth="120"/>

            </columns>

        </TableView>

    </children>
</AnchorPane>