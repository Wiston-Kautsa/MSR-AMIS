<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="550.0" prefWidth="850.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.UsersController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>

        <!-- ================= ADD USER SECTION ================= -->
        <TitledPane layoutX="20" layoutY="20" prefWidth="810" text="Add New User" expanded="true">

            <AnchorPane prefHeight="160">

                <children>

                    <!-- LEFT SIDE -->
                    <Label text="Full Name:" layoutX="20" layoutY="20"/>
                    <TextField fx:id="txtName" layoutX="120" layoutY="15" prefWidth="200"/>

                    <Label text="Username:" layoutX="20" layoutY="55"/>
                    <TextField fx:id="txtUsername" layoutX="120" layoutY="50" prefWidth="200"/>

                    <Label text="Phone:" layoutX="20" layoutY="90"/>
                    <TextField fx:id="txtPhone" layoutX="120" layoutY="85" prefWidth="200"/>

                    <!-- RIGHT SIDE -->
                    <Label text="Password:" layoutX="360" layoutY="20"/>
                    <PasswordField fx:id="txtPassword" layoutX="450" layoutY="15" prefWidth="200"/>

                    <Label text="Role:" layoutX="360" layoutY="55"/>
                    <ComboBox fx:id="cmbRole" layoutX="450" layoutY="50" prefWidth="200"/>

                    <Label text="Email:" layoutX="360" layoutY="90"/>
                    <TextField fx:id="txtEmail" layoutX="450" layoutY="85" prefWidth="200"/>

                    <!-- BUTTON -->
                    <Button text="Add User"
                            layoutX="680" layoutY="55"
                            prefWidth="100"
                            onAction="#handleAddUser"/>

                </children>
            </AnchorPane>
        </TitledPane>


        <!-- ================= USERS TABLE SECTION ================= -->
        <TitledPane layoutX="20" layoutY="200" prefWidth="810" prefHeight="320"
                    text="All Users" expanded="true">

            <AnchorPane>

                <children>

                    <TableView fx:id="tableUsers"
                               layoutX="10" layoutY="10"
                               prefWidth="790" prefHeight="250">

                        <columns>

                            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>

                            <TableColumn fx:id="colName" text="Full Name" prefWidth="160"/>

                            <TableColumn fx:id="colUsername" text="Username" prefWidth="140"/>

                            <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>

                            <TableColumn fx:id="colPhone" text="Phone" prefWidth="140"/>

                            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>

                        </columns>

                    </TableView>

                    <!-- DELETE BUTTON -->
                    <Button text="Delete User"
                            layoutX="650" layoutY="270"
                            prefWidth="140"
                            onAction="#handleDeleteUser"/>

                </children>

            </AnchorPane>
        </TitledPane>

    </children>

</AnchorPane>